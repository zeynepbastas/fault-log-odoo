<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="football_player_view_list" model="ir.ui.view">
        <field name="name">football.player.list</field>
        <field name="model">football.player</field>
        <field name="arch" type="xml">
            <list string="Players">
                <field name="name"/>
                <field name="team_id"/>
                <field name="position"/>
                <field name="jersey_number"/>
                <field name="age"/>
                <field name="market_value"/>
            </list>
        </field>
    </record>

    <record id="football_player_view_form" model="ir.ui.view">
        <field name="name">football.player.form</field>
        <field name="model">football.player</field>
        <field name="arch" type="xml">
            <form string="Player">
                <sheet>
                    <field name="photo" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Leo Martins"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="team_id"/>
                            <field name="position"/>
                            <field name="jersey_number"/>
                        </group>
                        <group>
                            <field name="age"/>
                            <field name="market_value"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="football_player_action" model="ir.actions.act_window">
        <field name="name">Players</field>
        <field name="res_model">football.player</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first player
            </p>
        </field>
    </record>

</odoo>
