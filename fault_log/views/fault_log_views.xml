<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fault_log_view_list" model="ir.ui.view">
        <field name="name">fault.log.list</field>
        <field name="model">fault.log</field>
        <field name="arch" type="xml">
            <list string="Fault Log">
                <field name="name"/>
                <field name="product_id"/>
                <field name="severity"/>
                <field name="date_reported"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="fault_log_view_form" model="ir.ui.view">
        <field name="name">fault.log.form</field>
        <field name="model">fault.log</field>
        <field name="arch" type="xml">
            <form string="Fault Log">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="new,investigating,resolved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Conveyor motor overheating"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="severity"/>
                        </group>
                        <group>
                            <field name="date_reported"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="fault_log_action" model="ir.actions.act_window">
        <field name="name">Fault Log</field>
        <field name="res_model">fault.log</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Log your first equipment fault
            </p>
        </field>
    </record>

    <menuitem id="fault_log_menu_root"
              name="Fault Log"
              sequence="90"/>

    <menuitem id="fault_log_menu_main"
              name="Faults"
              parent="fault_log_menu_root"
              action="fault_log_action"
              sequence="10"/>

</odoo>
